# ============================================================
# Helix OS .gitignore
# ============================================================

# ----- Python byte-compiled / optimized / DLL files -----
__pycache__/
*.py[codz]
*$py.class
*.so

# ----- Distribution / packaging -----
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
*.whl
MANIFEST

# ----- Environments -----
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.env.local
.env.production

# ----- AI/ML model files (too large for Git — download at install time) -----
*.onnx
*.bin
*.pt
*.pth
*.safetensors
models/

# ----- Audio test files -----
*.wav
*.mp3
*.flac
*.ogg

# ----- Node.js (helix_ui frontend) -----
node_modules/
src/helix_ui/static/

# ----- Logs and data -----
*.log
*.csv
latency_log.csv
*.sqlite
*.db
db.sqlite3
db.sqlite3-journal

# ----- Unit test / coverage reports -----
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ----- PyInstaller -----
*.manifest
*.spec

# ----- Installer logs -----
pip-log.txt
pip-delete-this-directory.txt

# ----- Translations -----
*.mo
*.pot

# ----- Type checkers / linters -----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ----- Package managers lock files (uncomment if needed) -----
#Pipfile.lock
#uv.lock
#poetry.lock
#poetry.toml
#pdm.lock
#pdm.toml
#pixi.lock
.pdm-python
.pdm-build/
.pixi
__pypackages__/

# ----- mkdocs documentation -----
/site

# ----- Celery -----
celerybeat-schedule
celerybeat.pid

# ----- SageMath -----
*.sage.py

# ----- Scrapy -----
.scrapy

# ----- Sphinx -----
docs/_build/

# ----- PyBuilder -----
.pybuilder/
target/

# ----- Jupyter / IPython -----
.ipynb_checkpoints
profile_default/
ipython_config.py

# ----- IDE and editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject
.cursorignore
.cursorindexingignore
.abstra/

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- PyPI -----
.pypirc

# ----- Marimo -----
marimo/_static/
marimo/_lsp/
__marimo__/

# ----- Flask / Django (not used but kept for completeness) -----
instance/
.webassets-cache
local_settings.py